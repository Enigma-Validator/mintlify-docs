    "/evm/ledger/transfers": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "List ledger transfers (L1 actions)",
        "description": "L1 ledger transfers including withdraw3, usdSend, spotSend, sendAsset, usdClassTransfer, subAccountTransfer, vaultTransfer.",
        "parameters": [
          {
            "name": "user",
            "in": "query",
            "description": "Filter by user address (from or to)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action_type",
            "in": "query",
            "description": "Filter by action type",
            "schema": {
              "type": "string",
              "enum": [
                "withdraw3",
                "usdSend",
                "spotSend",
                "sendAsset",
                "usdClassTransfer",
                "subAccountTransfer",
                "vaultTransfer"
              ]
            }
          },
          {
            "name": "token",
            "in": "query",
            "description": "Filter by token (partial match)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Start time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "End time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/evm/bridge/events": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "List bridge events (deposits/withdrawals)",
        "description": "Bridge deposit votes, withdrawal finalizations, and signature events.",
        "parameters": [
          {
            "name": "user_addr",
            "in": "query",
            "description": "Filter by user address",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event_type",
            "in": "query",
            "description": "Filter by event type",
            "schema": {
              "type": "string",
              "enum": [
                "deposit_vote",
                "withdrawal_finalized",
                "withdrawal_sign",
                "withdraw3"
              ]
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Start time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "End time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/evm/user/{address}/ledger-events": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "Non-funding ledger events for a user",
        "description": "Unified non-funding ledger history for a user. Combines ledger_transfers (usdSend, spotSend, sendAsset, withdraw3, usdClassTransfer, subAccountTransfer, vaultTransfer) and evm_bridge_events (deposit_vote, withdrawal_finalized).\n\nEvent types:\n- `deposit` — bridge deposit into Hyperliquid\n- `withdrawal` — withdraw3 or bridge withdrawal finalized\n- `transfer_in` — received via usdSend/spotSend/sendAsset\n- `transfer_out` — sent via usdSend/spotSend/sendAsset\n- `class_transfer` — perp ↔ spot USDC transfer\n- `sub_account` — sub-account transfer\n- `vault` — vault deposit/withdrawal",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "User address (0x…)",
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "event_type",
            "in": "query",
            "description": "Filter by event type(s) (repeat param for multiple)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "deposit",
                  "withdrawal",
                  "transfer_in",
                  "transfer_out",
                  "class_transfer",
                  "sub_account",
                  "vault"
                ]
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Start time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "End time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
