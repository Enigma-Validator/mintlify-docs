{
  "openapi": "3.0.3",
  "info": {
    "title": "HL Indexer API — EVM",
    "version": "1.0.0",
    "description": "EVM blockchain data: blocks, transactions, event logs, ledger transfers, bridge events."
  },
  "servers": [
    {
      "url": "https://api.hypedexer.com",
      "description": "EU production"
    }
  ],
  "tags": [
    {
      "name": "EVM",
      "description": "EVM blockchain data: blocks, transactions, logs, ledger transfers, bridge events."
    }
  ],
  "paths": {
    "/evm/stats": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "Global EVM indexing stats",
        "description": "Total blocks, transactions, logs indexed and block range.",
        "parameters": [
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/evm/stats/daily": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "Daily block/tx stats",
        "description": "Daily block and transaction counts over a configurable lookback window.",
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "description": "Number of days to look back",
            "schema": {
              "type": "integer",
              "default": 30,
              "minimum": 1,
              "maximum": 365
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/evm/blocks": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "List EVM blocks",
        "description": "Returns EVM blocks with optional filters on block range and time range.",
        "parameters": [
          {
            "name": "start_block",
            "in": "query",
            "description": "Min block number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "end_block",
            "in": "query",
            "description": "Max block number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Start time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "End time (UTC)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/evm/blocks/{block_number}": {
      "get": {
        "tags": [
          "EVM"
        ],
        "summary": "Get block by number",
        "description": "Returns a single EVM block by its block number.",
        "parameters": [
          {
            "name": "block_number",
            "in": "path",
            "required": true,
            "description": "Block number",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "default": true
                    },
                    "message": {
                      "type": "string",
                      "default": "OK"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Block not found"
          }
        }
      }
    },
    "/evm/transactions": {
      "get": {
        "tags": [
